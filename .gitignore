__pycache__/
*.pyc
.env
scripts/*.log

# Round-2: large / temporary / generated media (keep out of git)
# (git .gitignore has no inline comments — patterns must stand alone)
# Whisper model weights (~141 MB) — re-download via requirements.txt
models/*.bin
# temp frame/audio scratch from video analysis
video_work/
# uploaded / dropped source videos
inbox/
# video_toolkit outputs
media_lib/
# sites/ and synthesized/ are text artifacts — left tracked on purpose.
# Local task-tracker SQLite DB (bookkeeping state, not source)
second-brain-chat/task_tracker.db
second-brain-chat/task_tracker.db-journal

# Round-4: durable conversation memory DB — LOCAL + PRIVATE, never commit
second-brain-chat/conversation_memory.db
second-brain-chat/conversation_memory.db-journal
second-brain-chat/conversation_memory.db-wal
second-brain-chat/conversation_memory.db-shm
# Screen-watch: captured screenshots are processed then deleted; never commit any
screenshots/

# Round-5: unified semantic index (embeds vault + conversations + reports + tasks) — LOCAL, never commit
second-brain-chat/semantic_index.db
second-brain-chat/semantic_index.db-journal
second-brain-chat/semantic_index.db-wal
second-brain-chat/semantic_index.db-shm
# Background job queue state (local, persists across restarts) — state, not source
second-brain-chat/jobs.db
second-brain-chat/jobs.db-journal
second-brain-chat/jobs.db-wal
second-brain-chat/jobs.db-shm
# Vendored local embedding model (potion-base-8M, ~31 MB) — re-downloadable via requirements
models/potion-base-8M/
# Local test-suite last-green-run marker (state, not source)
.last_test_pass
# Round-5: captured notes staging — the notes can hold pasted/personal content, so keep the
# .md files local (private); the README explaining the folder stays tracked.
vault_inbox/*.md
!vault_inbox/README.md
# Round-5: tool audit log + cost tracking DBs — LOCAL + PRIVATE, never commit
second-brain-chat/observability.db
second-brain-chat/observability.db-journal
second-brain-chat/observability.db-wal
second-brain-chat/observability.db-shm
# run drafts are text (tracked on purpose), but the launch state index stays local
# (kept tracked — small JSON; drafts are useful history)
second-brain-chat/imessage_cursor.json
