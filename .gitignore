__pycache__/
*.pyc
.env
scripts/*.log

# Round-2: large / temporary / generated media (keep out of git)
# (git .gitignore has no inline comments — patterns must stand alone)
# Whisper model weights (~141 MB) — re-download via requirements.txt
models/*.bin
# temp frame/audio scratch from video analysis
video_work/
# uploaded / dropped source videos
inbox/
# video_toolkit outputs
media_lib/
# sites/ and synthesized/ are text artifacts — left tracked on purpose.
# Local task-tracker SQLite DB (bookkeeping state, not source)
second-brain-chat/task_tracker.db
second-brain-chat/task_tracker.db-journal

# Round-4: durable conversation memory DB — LOCAL + PRIVATE, never commit
second-brain-chat/conversation_memory.db
second-brain-chat/conversation_memory.db-journal
second-brain-chat/conversation_memory.db-wal
second-brain-chat/conversation_memory.db-shm
# Screen-watch: captured screenshots are processed then deleted; never commit any
screenshots/
# run drafts are text (tracked on purpose), but the launch state index stays local
# (kept tracked — small JSON; drafts are useful history)
