# ---------------------------------------------------------------------------
# second-brain — example environment file.
# Copy to `.env` and fill in real values.  `.env` is gitignored; never commit it.
# This lists EVERY variable the system reads. Required ones are uncommented with
# placeholders; optional ones are commented with their default noted.
# ---------------------------------------------------------------------------

# --- API credentials (required) ---
CLAUDE_API_KEY=sk-ant-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...
COMPOSIO_API_KEY=ak_...

# --- Chat access gate (required) ---
# Passphrase required by the chat UI (entered once per browser). Blank = open access.
# Legacy alias JARVIS_PASSWORD is still accepted if ACCESS_CODE is unset.
ACCESS_CODE=change-me-to-a-long-random-string

# --- Flask session signing key (required; any long random hex string) ---
# Keep it stable so logins survive an app restart.
FLASK_SECRET_KEY=change-me

# --- Vaults ---
# VAULT_PATH: the agent-WRITABLE, git-synced copy of the vault (list/read/write_vault_note
# tools). Defaults to the iCloud "Second brain" folder; override when deployed elsewhere.
# VAULT_PATH=/Users/you/Library/Mobile Documents/com~apple~CloudDocs/Obsidian/Second brain
#
# OBSIDIAN_VAULT_PATH: the real, READ-ONLY Obsidian vault the search/index tools read
# (search_notes / read_note / list_recent_notes). Never modified. Point at sample_vault to demo.
# OBSIDIAN_VAULT_PATH=/Users/you/Library/Mobile Documents/iCloud~md~obsidian/Documents/Second brain

# --- Network / runtime ---
PORT=5001
# HOST defaults to 127.0.0.1 (localhost only). Only change if you understand the exposure
# (see SECURITY_NOTES.md) — never combine 0.0.0.0 with FLASK_DEBUG=1.
# HOST=127.0.0.1
# FLASK_DEBUG defaults to 0 (off). The Werkzeug debugger is a remote-code-execution vector.
# FLASK_DEBUG=0
# JARVIS_RUNTIME tags which instance this is so the Task Manager's worker only claims tasks
# whose runtime matches. Auto-detected: "local" on the Mac, "server" in the container. Values:
# local | server | any.
# JARVIS_RUNTIME=local
# TRUSTED_PROXY_COUNT: how many reverse proxies sit in front of the app (server behind
# Coolify/Traefik: 1). Enables X-Forwarded-For/-Proto handling so the login rate limiter
# sees real client IPs. Leave unset/0 when the app is reached directly (local Mac) —
# trusting those headers without a proxy would let clients spoof their IP.
# TRUSTED_PROXY_COUNT=0
# SESSION_COOKIE_SECURE: set to 1 once the site is served over HTTPS so the session
# cookie is never sent over plain HTTP. Must stay 0 for local http://127.0.0.1 use.
# SESSION_COOKIE_SECURE=0

# --- Optional web-search providers (data synthesizer) ---
# If none are set, the synthesizer falls back to keyless DuckDuckGo. Set any to use it instead.
# TAVILY_API_KEY=tvly-...
# SERPER_API_KEY=...
# BRAVE_API_KEY=...

# --- Semantic search / memory tuning (optional) ---
# EMBED_MODEL_ID: the model2vec static-embedding model (default minishlab/potion-base-8M, ~31 MB).
# EMBED_MODEL_ID=minishlab/potion-base-8M
# MEMORY_SESSION_GAP: minutes of inactivity that close+summarize a conversation session (default 45).
# MEMORY_SESSION_GAP=45

# --- Proactive nudges (optional — without NTFY_TOPIC nothing can send) ---
# NTFY_TOPIC: the private ntfy.sh topic nudges publish to. The topic NAME is the
# only secret — make it long and random (anyone who knows it can post/subscribe).
# Set the SAME value on the server (Coolify env) and subscribe to it in the ntfy app.
# NTFY_TOPIC=clarvis-<long-random-string>
# NTFY_SERVER: alternate ntfy server (default https://ntfy.sh).
# NTFY_SERVER=https://ntfy.sh
# JARVIS_PUBLIC_URL: where nudge taps deep-link to (default the clarvis sslip.io URL).
# JARVIS_PUBLIC_URL=https://clarvis.178.156.209.40.sslip.io
# PROACTIVE_LOCAL: set 1 to ALSO run the 15-min awareness worker on this Mac
# (default: server-only; local stays manual via run_awareness_now).
# PROACTIVE_LOCAL=0

# --- Voice (optional — ElevenLabs; without a key, local whisper/say/browser voices) ---
# ELEVENLABS_API_KEY: enables Scribe speech-to-text (push-to-talk works on the phone/
# server, not just the Mac) and Jarvis's spoken-reply voice. Create at elevenlabs.io →
# Profile → API keys. Set the SAME key in Coolify for the server.
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID: which voice Jarvis speaks with (default: George — deep, calm,
# British). Browse ids at elevenlabs.io/app/voice-library.
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# --- Self-Expanding Pipeline (optional) ---
# GITHUB_TOKEN: read-only GitHub token used ONLY by the expansion scout's repo search
# (expansion_pipeline.py) to raise the GitHub API rate limit. Unauthenticated search works
# too, just slower/rate-limited. A classic PAT needs no scopes (or public_repo) for public
# search; a fine-grained token needs only public repository read. Never hardcode it.
# GITHUB_TOKEN=ghp_...
