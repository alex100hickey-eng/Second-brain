# ---------------------------------------------------------------------------
# second-brain — example environment file.
# Copy to `.env` and fill in real values.  `.env` is gitignored; never commit it.
# ---------------------------------------------------------------------------

# --- API credentials ---
CLAUDE_API_KEY=sk-ant-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...
COMPOSIO_API_KEY=ak_...

# --- Chat access gate ---
# Passphrase required by the chat UI (entered once per browser). Blank = open access.
ACCESS_CODE=change-me-to-a-long-random-string

# --- Flask session signing key (any long random hex string) ---
FLASK_SECRET_KEY=change-me

# --- Read-only Obsidian vault for the search/index tools ---
# Defaults to the real Obsidian vault if unset. Point at sample_vault to demo.
# OBSIDIAN_VAULT_PATH=/Users/you/Library/Mobile Documents/iCloud~md~obsidian/Documents/Second brain

# --- Network / runtime ---
PORT=5001
# HOST defaults to 127.0.0.1 (localhost only). FLASK_DEBUG defaults to 0 (off).
